{
  "description": "machinery design governance for Claude Code and Codex. Every hook routes through one shim that exits 0 immediately unless the project root has .machinery.json or design/domain.modelith.yaml, so non-machinery repos are never disturbed. PreToolUse denies hand-edits to generated artifacts; PostToolUse records what the session touched; Stop/SubagentStop run the deterministic gates before the turn may end; SessionStart announces the governance contract.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|apply_patch|edit|write|patch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/machinery-hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|apply_patch|edit|write|patch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/machinery-hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/machinery-hook.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/machinery-hook.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/machinery-hook.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
