{
  "_comment": "FulfillmentSaga orchestrator: forward path reserve -> pay -> ship, and on any failure a single idempotent compensate step (refund if captured, release if reserved), retried with a bound. Clean termination is Completed or Failed; if compensation cannot complete within the retry bound it ends FailedDirty, the explicit residual that needs manual intervention. PLACEMENT: a persistent saga process per order (Elixir gen_statem under a Registry, state journaled). Corrected after the data-refined model (SagaData) showed a single refund attempt could leave a captured payment un-refunded.",
  "_delays": {
    "reserveTimeout": "5000 ms",
    "payTimeout": "8000 ms",
    "shipTimeout": "8000 ms",
    "compensateTimeout": "8000 ms",
    "compensateBackoff": "500 ms - compensation retry backoff; give up to FailedDirty at 3"
  },
  "id": "fulfillmentSaga",
  "initial": "Reserving",
  "context": { "orderId": null, "retries": 0 },
  "states": {
    "Reserving": {
      "invoke": {
        "src": "reserveInventory",
        "onDone": { "target": "Paying", "actions": "markReserved" },
        "onError": { "target": "Failed", "actions": "recordReserveFailed" }
      },
      "after": { "reserveTimeout": { "target": "Failed", "actions": "recordReserveTimeout" } }
    },
    "Paying": {
      "invoke": {
        "src": "capturePayment",
        "onDone": { "target": "Shipping", "actions": "markPaid" },
        "onError": { "target": "Compensating", "actions": "recordPayFailed" }
      },
      "after": { "payTimeout": { "target": "Compensating", "actions": "recordPayTimeout" } }
    },
    "Shipping": {
      "invoke": {
        "src": "dispatchShipment",
        "onDone": { "target": "Completed", "actions": "markShipped" },
        "onError": { "target": "Compensating", "actions": "recordShipFailed" }
      },
      "after": { "shipTimeout": { "target": "Compensating", "actions": "recordShipTimeout" } }
    },
    "Compensating": {
      "invoke": {
        "src": "compensate",
        "onDone": { "target": "Failed", "actions": "recordCompensated" },
        "onError": { "target": "compensateRetry", "actions": "recordCompensateError" }
      },
      "after": { "compensateTimeout": { "target": "compensateRetry", "actions": "recordCompensateTimeout" } }
    },
    "compensateRetry": {
      "always": [
        { "target": "FailedDirty", "guard": "retriesExhausted", "actions": "recordCompensationIncomplete" }
      ],
      "after": { "compensateBackoff": { "target": "Compensating", "actions": "incrementRetries" } }
    },
    "Completed": { "type": "final" },
    "Failed": { "type": "final" },
    "FailedDirty": { "type": "final" }
  }
}
